# Local development environment variables
# Copy this file to .dev.vars and fill in your values
# .dev.vars is already in .gitignore - DO NOT COMMIT IT

# Admin email address (authorized for login)
ADMIN_EMAIL=magnus.hultberg@gmail.com

# JWT secret for signing session tokens
# Generate with: openssl rand -base64 32
JWT_SECRET=your-local-dev-secret-key-replace-this

# Resend.com API key for sending magic link emails
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here

# GitHub Personal Access Token (Phase 6+)
# Generate at: https://github.com/settings/tokens
# Permissions: Contents (Read and write) for hultberg-org repo
GITHUB_TOKEN=github_pat_your_token_here

# Google Search Console service-account key (stringified JSON).
# The service account must be added as a user on the sc-domain:hultberg.org
# property with Owner or Full permission.
# Setup: REFERENCE/environment-setup.md → "GSC service account"
# Production: set via `wrangler secret put GSC_SERVICE_ACCOUNT_JSON` (never commit).
GSC_SERVICE_ACCOUNT_JSON='{"type":"service_account","client_email":"...","private_key":"..."}'
